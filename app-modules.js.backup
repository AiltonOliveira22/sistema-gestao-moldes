// Custos
AppManager.prototype.showCustoForm = function(item = null) {
    const content = `
        <form id="custoForm">
            <div class="form-row">
                <div class="form-group">
                    <label>SKU *</label>
                    <input type="text" name="sku" value="${item && item.sku || ''}" required placeholder="Ex: Stella">
                </div>
                <div class="form-group">
                    <label>Item (Número) *</label>
                    <input type="number" name="item" value="${item && item.item || ''}" required>
                </div>
            </div>
            <div class="form-group">
                <label>Tipo de Molde *</label>
                <input type="text" name="tipoMolde" value="${item && item.tipoMolde || ''}" required placeholder="Ex: BLOW MOULD">
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Tradução *</label>
                    <input type="text" name="traducao" value="${item && item.traducao || ''}" required placeholder="Ex: MOLDE">
                </div>
                <div class="form-group">
                    <label>Classificação *</label>
                    <select name="classificacao" required>
                        <option value="">Selecione...</option>
                        <option value="MOULD" ${item && item.classificacao === 'MOULD' ? 'selected' : ''}>MOULD (Molde)</option>
                        <option value="ACESSÓRIO" ${item && item.classificacao === 'ACESSÓRIO' ? 'selected' : ''}>ACESSÓRIO</option>
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label>Fornecedor *</label>
                <input type="text" name="fornecedor" value="${item && item.fornecedor || ''}" required placeholder="Ex: Fornecedor ABC">
            </div>
            <div class="form-group">
                <label>Quantidade *</label>
                <input type="number" name="quantidade" value="${item && item.quantidade || ''}" required min="1">
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Moeda *</label>
                    <select name="moeda" required>
                        <option value="EUR" ${!item || item.moeda === 'EUR' ? 'selected' : ''}>€ Euro</option>
                        <option value="USD" ${item && item.moeda === 'USD' ? 'selected' : ''}>$ Dólar</option>
                        <option value="BRL" ${item && item.moeda === 'BRL' ? 'selected' : ''}>R$ Real</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Valor Unitário *</label>
                    <input type="number" name="valorUnitario" value="${item && item.valorUnitario || ''}" required min="0" step="0.01" placeholder="0.00">
                </div>
            </div>
            <div style="background: #eff6ff; padding: 15px; border-radius: 8px; margin-top: 15px;">
                <strong style="color: #2563eb;">ℹ️ Cálculo Automático</strong>
                <p style="margin: 5px 0 0 0; color: #475569;">O Valor Total será calculado automaticamente: Quantidade × Valor Unitário</p>
            </div>
        </form>
    `;

    this.modal.show(item ? 'Editar Item de Custo' : 'Adicionar Item de Custo', content, () => {
        const form = document.getElementById('custoForm');
        if (!form.checkValidity()) {
            form.reportValidity();
            return false;
        }

        const formData = new FormData(form);
        const data = Object.fromEntries(formData);
        
        // Converter números
        data.item = parseInt(data.item);
        data.quantidade = parseInt(data.quantidade);
        data.valorUnitario = parseFloat(data.valorUnitario);
        data.valorTotal = data.quantidade * data.valorUnitario;

        if (item) {
            this.storage.updateItem('custos', item.id, data);
            this.notification.show('success', 'Sucesso', 'Item atualizado com sucesso!');
        } else {
            this.storage.addItem('custos', data);
            this.notification.show('success', 'Sucesso', 'Item adicionado com sucesso!');
        }

        this.renderCustos();
        return true;
    });
};

AppManager.prototype.renderCustos = function() {
    const items = this.storage.getModule('custos');
    const tbody = document.getElementById('custosTable');
    
    // Renderizar tabela
    if (items.length === 0) {
        tbody.innerHTML = '<tr><td colspan="9" class="empty-message">Nenhum item cadastrado</td></tr>';
        this.updateCustosStats(items);
        return;
    }

    tbody.innerHTML = items.map(item => {
        const classificacaoBadge = item.classificacao === 'MOULD' ? 'danger' : 'info';
        const moeda = item.moeda || 'EUR';
        const simboloMoeda = { 'EUR': '€', 'USD': '$', 'BRL': 'R$' }[moeda] || '€';
        
        return `
            <tr>
                <td><strong>${item.sku}</strong></td>
                <td><span class="badge badge-secondary">#${item.item}</span></td>
                <td>${item.tipoMolde}<br><small style="color: var(--text-secondary);">${item.traducao}</small></td>
                <td><span class="badge badge-${classificacaoBadge}">${item.classificacao}</span></td>
                <td><span class="badge badge-warning">${item.fornecedor || 'N/A'}</span></td>
                <td><strong>${item.quantidade}</strong> un.</td>
                <td style="text-align: right;">${simboloMoeda} ${item.valorUnitario.toFixed(2)}</td>
                <td style="text-align: right;"><strong style="color: #10b981;">${simboloMoeda} ${item.valorTotal.toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</strong></td>
                <td>
                    <button class="btn btn-sm btn-primary" onclick="window.app.editCusto('${item.id}')">
                        <i class="fas fa-edit"></i>
                    </button>
                    <button class="btn btn-sm btn-danger" onclick="window.app.deleteCusto('${item.id}')">
                        <i class="fas fa-trash"></i>
                    </button>
                </td>
            </tr>
        `;
    }).join('');
    
    // Atualizar estatísticas e gráfico
    this.updateCustosStats(items);
};

AppManager.prototype.updateCustosStats = function(items) {
    // Popular dropdown de fornecedores
    const fornecedorFilter = document.getElementById('fornecedorFilter');
    if (fornecedorFilter) {
        const fornecedores = [...new Set(items.map(item => item.fornecedor).filter(f => f))];
        const currentValue = fornecedorFilter.value;
        
        fornecedorFilter.innerHTML = '<option value="">Todos os Fornecedores</option>' + 
            fornecedores.map(f => `<option value="${f}" ${currentValue === f ? 'selected' : ''}>${f}</option>`).join('');
        
        // Adicionar evento de mudança se ainda não existe
        if (!fornecedorFilter.dataset.listenerAdded) {
            fornecedorFilter.addEventListener('change', () => {
                this.renderCustos();
            });
            fornecedorFilter.dataset.listenerAdded = 'true';
        }
        
        // Filtrar itens pelo fornecedor selecionado
        if (fornecedorFilter.value) {
            items = items.filter(item => item.fornecedor === fornecedorFilter.value);
        }
    }
    
    // Calcular estatísticas (em EUR por padrão)
    const totalInvestido = items.reduce((sum, item) => sum + item.valorTotal, 0);
    const custoMedio = items.length > 0 ? totalInvestido / items.length : 0;
    
    let moldeBarato = { valorTotal: Infinity, moeda: 'EUR' };
    let moldeCaro = { valorTotal: 0, moeda: 'EUR' };
    
    items.forEach(item => {
        if (item.valorTotal < moldeBarato.valorTotal) moldeBarato = item;
        if (item.valorTotal > moldeCaro.valorTotal) moldeCaro = item;
    });
    
    // Símbolo EUR padrão para dashboard
    const simbolo = '€';
    
    // Atualizar cards
    const totalInvestidoEl = document.getElementById('totalInvestido');
    const custoMedioEl = document.getElementById('custoMedio');
    const moldeBaratoEl = document.getElementById('moldeBarato');
    const moldeCaroEl = document.getElementById('moldeCaro');
    
    if (totalInvestidoEl) totalInvestidoEl.textContent = `${simbolo} ${totalInvestido.toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
    if (custoMedioEl) custoMedioEl.textContent = `${simbolo} ${custoMedio.toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
    if (moldeBaratoEl) moldeBaratoEl.textContent = moldeBarato.valorTotal !== Infinity ? `${simbolo} ${moldeBarato.valorTotal.toLocaleString('pt-BR', {minimumFractionDigits: 2})}` : `${simbolo} 0`;
    if (moldeCaroEl) moldeCaroEl.textContent = moldeCaro.valorTotal > 0 ? `${simbolo} ${moldeCaro.valorTotal.toLocaleString('pt-BR', {minimumFractionDigits: 2})}` : `${simbolo} 0`;
    
    // Criar gráfico
    this.renderCustosChart(items);
};

AppManager.prototype.renderCustosChart = function(items) {
    const canvas = document.getElementById('custosChart');
    if (!canvas) return;
    
    // Destruir gráfico existente
    if (window.custosChartInstance) {
        window.custosChartInstance.destroy();
    }
    
    if (items.length === 0) {
        canvas.getContext('2d').clearRect(0, 0, canvas.width, canvas.height);
        return;
    }
    
    // Preparar dados (Top 10 mais caros)
    const sorted = [...items].sort((a, b) => b.valorTotal - a.valorTotal).slice(0, 10);
    const labels = sorted.map(item => item.traducao);
    const valores = sorted.map(item => item.valorTotal);
    const cores = sorted.map(item => item.classificacao === 'MOULD' ? '#ef4444' : '#2563eb');
    
    // Criar gráfico
    window.custosChartInstance = new Chart(canvas, {
        type: 'bar',
        data: {
            labels: labels,
            datasets: [{
                label: 'Valor Total (€)',
                data: valores,
                backgroundColor: cores,
                borderColor: cores,
                borderWidth: 2,
                borderRadius: 8
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    display: false
                },
                title: {
                    display: true,
                    text: 'Top 10 Itens Mais Caros',
                    font: {
                        size: 18,
                        weight: 'bold'
                    },
                    color: '#e8e9ed'
                },
                tooltip: {
                    backgroundColor: 'rgba(0, 0, 0, 0.8)',
                    padding: 12,
                    titleFont: {
                        size: 14,
                        weight: 'bold'
                    },
                    bodyFont: {
                        size: 13
                    },
                    callbacks: {
                        label: function(context) {
                            return 'Valor Total: € ' + context.parsed.y.toLocaleString('pt-BR', {minimumFractionDigits: 2});
                        }
                    }
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        callback: function(value) {
                            return '€ ' + value.toLocaleString('pt-BR');
                        },
                        font: {
                            size: 11
                        },
                        color: '#8b92ab'
                    },
                    grid: {
                        color: 'rgba(255, 255, 255, 0.05)'
                    }
                },
                x: {
                    ticks: {
                        font: {
                            size: 11,
                            weight: 'bold'
                        },
                        color: '#8b92ab',
                        maxRotation: 45,
                        minRotation: 45
                    },
                    grid: {
                        display: false
                    }
                }
            }
        }
    });
};

AppManager.prototype.deleteCusto = function(id) {
    if (confirm('Tem certeza que deseja excluir este item de custo?')) {
        this.storage.deleteItem('custos', id);
        this.notification.show('success', 'Sucesso', 'Item excluído com sucesso!');
        this.renderCustos();
    }
};

AppManager.prototype.editCusto = function(id) {
    const items = this.storage.getModule('custos');
    const item = items.find(i => i.id === id);
    if (item) this.showCustoForm(item);
};

// Initialize app
// Inicialização global
document.addEventListener('DOMContentLoaded', () => {
    window.app = new AppManager();
});
    const formHtml = `
        <form id="viabilidadeForm" onsubmit="return false;">
            <div class="form-row">
                <div class="form-group">
                    <label>Nome do Projeto *</label>
                    <input type="text" name="nomeProjeto" value="${item ? item.nomeProjeto : ''}" required>
                </div>
                <div class="form-group">
                    <label>Área *</label>
                    <select name="area" required>
                        <option value="">Selecione...</option>
                        <option value="Manutenção" ${item && item.area === 'Manutenção' ? 'selected' : ''}>Manutenção</option>
                        <option value="Produção" ${item && item.area === 'Produção' ? 'selected' : ''}>Produção</option>
                        <option value="Qualidade" ${item && item.area === 'Qualidade' ? 'selected' : ''}>Qualidade</option>
                        <option value="Engenharia" ${item && item.area === 'Engenharia' ? 'selected' : ''}>Engenharia</option>
                        <option value="Logística" ${item && item.area === 'Logística' ? 'selected' : ''}>Logística</option>
                        <option value="TI" ${item && item.area === 'TI' ? 'selected' : ''}>TI</option>
                    </select>
                </div>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <label>Responsável *</label>
                    <input type="text" name="responsavel" value="${item ? item.responsavel : ''}" required>
                </div>
                <div class="form-group">
                    <label>Data Início *</label>
                    <input type="date" name="dataInicio" value="${item ? item.dataInicio : ''}" required>
                </div>
            </div>
            
            <div class="form-group">
                <label>Descrição *</label>
                <textarea name="descricao" rows="3" required>${item ? item.descricao : ''}</textarea>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <label>Investimento Inicial (€) *</label>
                    <input type="number" name="investimentoInicial" step="0.01" min="0" 
                           value="${item ? item.investimentoInicial : ''}" required>
                </div>
                <div class="form-group">
                    <label>Economia Anual (€) *</label>
                    <input type="number" name="economiaAnual" step="0.01" min="0" 
                           value="${item ? item.economiaAnual : ''}" required>
                </div>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <label>Custo Operacional (€)</label>
                    <input type="number" name="custoOperacional" step="0.01" min="0" 
                           value="${item ? item.custoOperacional : 0}">
                </div>
                <div class="form-group">
                    <label>Vida Útil (anos) *</label>
                    <input type="number" name="vidaUtil" min="1" max="50" 
                           value="${item ? item.vidaUtil : 5}" required>
                </div>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <label>Taxa de Desconto (%) *</label>
                    <input type="number" name="taxaDesconto" step="0.1" min="0" max="100" 
                           value="${item ? item.taxaDesconto : 10}" required>
                </div>
                <div class="form-group">
                    <label>Prioridade *</label>
                    <select name="prioridade" required>
                        <option value="Alta" ${item && item.prioridade === 'Alta' ? 'selected' : ''}>Alta</option>
                        <option value="Média" ${item && item.prioridade === 'Média' ? 'selected' : ''}>Média</option>
                        <option value="Baixa" ${item && item.prioridade === 'Baixa' ? 'selected' : ''}>Baixa</option>
                    </select>
                </div>
            </div>
            
            <div class="form-group">
                <label>Benefícios Qualitativos</label>
                <textarea name="beneficiosQualitativos" rows="2">${item ? item.beneficiosQualitativos || '' : ''}</textarea>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <label>Risco</label>
                    <select name="risco">
                        <option value="Baixo" ${item && item.risco === 'Baixo' ? 'selected' : ''}>Baixo</option>
                        <option value="Médio" ${item && item.risco === 'Médio' ? 'selected' : ''}>Médio</option>
                        <option value="Alto" ${item && item.risco === 'Alto' ? 'selected' : ''}>Alto</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Status *</label>
                    <select name="status" required>
                        <option value="Pendente" ${item && item.status === 'Pendente' ? 'selected' : ''}>Pendente</option>
                        <option value="Em Análise" ${item && item.status === 'Em Análise' ? 'selected' : ''}>Em Análise</option>
                        <option value="Aprovado" ${item && item.status === 'Aprovado' ? 'selected' : ''}>Aprovado</option>
                        <option value="Rejeitado" ${item && item.status === 'Rejeitado' ? 'selected' : ''}>Rejeitado</option>
                        <option value="Em Execução" ${item && item.status === 'Em Execução' ? 'selected' : ''}>Em Execução</option>
                    </select>
                </div>
            </div>
        </form>
    `;
    
    const self = this;
    this.modal.show(
        item ? 'Editar Projeto' : 'Novo Projeto',
        formHtml,
        function() {
            const form = document.getElementById('viabilidadeForm');
            if (!form.checkValidity()) {
                form.reportValidity();
                return false;
            }
            
            const formData = new FormData(form);
            const data = {};
            formData.forEach((value, key) => {
                data[key] = value;
            });
            
            // Converter números
            data.investimentoInicial = parseFloat(data.investimentoInicial);
            data.economiaAnual = parseFloat(data.economiaAnual);
            data.custoOperacional = parseFloat(data.custoOperacional) || 0;
            data.vidaUtil = parseInt(data.vidaUtil);
            data.taxaDesconto = parseFloat(data.taxaDesconto);
            
            // Calcular métricas
            const metricas = self.calcularMetricas(data);
            Object.assign(data, metricas);
            
            if (item) {
                // Editar
                data.id = item.id;
                data.createdAt = item.createdAt;
                const index = self.data.viabilidade.findIndex(p => p.id === item.id);
                self.data.viabilidade[index] = data;
                self.notification.show('Projeto atualizado!', 'success');
            } else {
                // Adicionar novo
                data.id = self.generateId();
                data.createdAt = new Date().toISOString();
                self.data.viabilidade.push(data);
                self.notification.show('Projeto adicionado!', 'success');
            }
            
            self.saveData(self.data);
            self.renderViabilidade();
            return true;
        }
    );
};

// Calcular métricas financeiras
AppManager.prototype.calcularMetricas = function(projeto) {
    const inv = projeto.investimentoInicial;
    const eco = projeto.economiaAnual;
    const custo = projeto.custoOperacional;
    const vida = projeto.vidaUtil;
    const taxa = projeto.taxaDesconto / 100;
    
    const fluxoAnual = eco - custo;
    
    // ROI
    const roi = ((eco * vida - inv) / inv * 100).toFixed(2);
    
    // Payback
    const payback = fluxoAnual > 0 ? (inv / fluxoAnual).toFixed(2) : 'N/A';
    
    // VPL
    let vpl = -inv;
    for (let ano = 1; ano <= vida; ano++) {
        vpl += fluxoAnual / Math.pow(1 + taxa, ano);
    }
    vpl = parseFloat(vpl.toFixed(2));
    
    // TIR (aproximação)
    let tir = 0.1;
    for (let i = 0; i < 20; i++) {
        let f = -inv;
        let df = 0;
        for (let ano = 1; ano <= vida; ano++) {
            f += fluxoAnual / Math.pow(1 + tir, ano);
            df -= ano * fluxoAnual / Math.pow(1 + tir, ano + 1);
        }
        if (Math.abs(f) < 0.01) break;
        tir = tir - f / df;
    }
    const tirPercent = (tir * 100).toFixed(2);
    
    return {
        roi: parseFloat(roi),
        payback: payback === 'N/A' ? payback : parseFloat(payback),
        vpl: vpl,
        tir: tirPercent
    };
};

// Renderizar lista de projetos
AppManager.prototype.renderViabilidade = function() {
    const projetos = this.data.viabilidade || [];
    const tbody = document.getElementById('viabilidadeTable');
    
    if (projetos.length === 0) {
        tbody.innerHTML = '<tr><td colspan="9" class="empty-message">Nenhum projeto cadastrado</td></tr>';
        this.updateViabilidadeStats([]);
        return;
    }
    
    tbody.innerHTML = projetos.map(p => {
        const roiClass = p.roi > 50 ? 'success' : p.roi > 20 ? 'warning' : 'danger';
        const statusClass = p.status === 'Aprovado' ? 'success' : 
                          p.status === 'Rejeitado' ? 'danger' : 
                          p.status === 'Em Execução' ? 'info' : 'warning';
        
        return `
            <tr>
                <td><strong>${p.nomeProjeto}</strong></td>
                <td>${p.area}</td>
                <td>€ ${p.investimentoInicial.toLocaleString('pt-BR', {minimumFractionDigits: 2})}</td>
                <td>€ ${p.economiaAnual.toLocaleString('pt-BR', {minimumFractionDigits: 2})}</td>
                <td><span class="badge badge-${roiClass}">${p.roi}%</span></td>
                <td>${p.payback} anos</td>
                <td style="color: ${p.vpl > 0 ? 'var(--success-color)' : 'var(--danger-color)'};">
                    € ${p.vpl.toLocaleString('pt-BR', {minimumFractionDigits: 2})}
                </td>
                <td><span class="badge badge-${statusClass}">${p.status}</span></td>
                <td class="actions">
                    <button class="btn-icon btn-edit" onclick="app.editViabilidade('${p.id}')" title="Editar">
                        <i class="fas fa-edit"></i>
                    </button>
                    <button class="btn-icon btn-delete" onclick="app.deleteViabilidade('${p.id}')" title="Excluir">
                        <i class="fas fa-trash"></i>
                    </button>
                </td>
            </tr>
        `;
    }).join('');
    
    this.updateViabilidadeStats(projetos);
};

// Atualizar estatísticas
AppManager.prototype.updateViabilidadeStats = function(projetos) {
    const total = projetos.length;
    const aprovados = projetos.filter(p => p.status === 'Aprovado').length;
    const pendentes = projetos.filter(p => p.status === 'Pendente' || p.status === 'Em Análise').length;
    const investTotal = projetos.reduce((sum, p) => sum + p.investimentoInicial, 0);
    
    document.getElementById('totalProjetos').textContent = total;
    document.getElementById('projetosAprovados').textContent = aprovados;
    document.getElementById('projetosPendentes').textContent = pendentes;
    document.getElementById('investimentoTotal').textContent = 
        '€ ' + investTotal.toLocaleString('pt-BR', {minimumFractionDigits: 2});
    
    this.renderViabilidadeCharts(projetos);
};

// Renderizar gráficos
AppManager.prototype.renderViabilidadeCharts = function(projetos) {
    if (projetos.length === 0) return;
    
    // Top 5 ROI
    const topRoi = [...projetos].sort((a, b) => b.roi - a.roi).slice(0, 5);
    const roiCanvas = document.getElementById('roiChart');
    
    if (this.roiChart) this.roiChart.destroy();
    
    this.roiChart = new Chart(roiCanvas, {
        type: 'bar',
        data: {
            labels: topRoi.map(p => p.nomeProjeto),
            datasets: [{
                label: 'ROI (%)',
                data: topRoi.map(p => p.roi),
                backgroundColor: topRoi.map(p => 
                    p.roi > 50 ? 'rgba(16, 185, 129, 0.8)' : 
                    p.roi > 20 ? 'rgba(245, 158, 11, 0.8)' : 
                    'rgba(239, 68, 68, 0.8)'
                ),
                borderColor: topRoi.map(p => 
                    p.roi > 50 ? 'rgba(16, 185, 129, 1)' : 
                    p.roi > 20 ? 'rgba(245, 158, 11, 1)' : 
                    'rgba(239, 68, 68, 1)'
                ),
                borderWidth: 2
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    backgroundColor: 'rgba(22, 27, 46, 0.95)',
                    titleColor: '#e8e9ed',
                    bodyColor: '#8b92ab'
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { color: '#8b92ab' },
                    grid: { color: 'rgba(255, 255, 255, 0.05)' }
                },
                x: {
                    ticks: { color: '#8b92ab' },
                    grid: { color: 'rgba(255, 255, 255, 0.05)' }
                }
            }
        }
    });
    
    // Top 5 Payback
    const topPayback = [...projetos]
        .filter(p => p.payback !== 'N/A')
        .sort((a, b) => a.payback - b.payback)
        .slice(0, 5);
    
    const paybackCanvas = document.getElementById('paybackChart');
    
    if (this.paybackChart) this.paybackChart.destroy();
    
    this.paybackChart = new Chart(paybackCanvas, {
        type: 'bar',
        data: {
            labels: topPayback.map(p => p.nomeProjeto),
            datasets: [{
                label: 'Payback (anos)',
                data: topPayback.map(p => p.payback),
                backgroundColor: 'rgba(59, 130, 246, 0.8)',
                borderColor: 'rgba(59, 130, 246, 1)',
                borderWidth: 2
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    backgroundColor: 'rgba(22, 27, 46, 0.95)',
                    titleColor: '#e8e9ed',
                    bodyColor: '#8b92ab'
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { color: '#8b92ab' },
                    grid: { color: 'rgba(255, 255, 255, 0.05)' }
                },
                x: {
                    ticks: { color: '#8b92ab' },
                    grid: { color: 'rgba(255, 255, 255, 0.05)' }
                }
            }
        }
    });
};

// Excluir projeto
AppManager.prototype.deleteViabilidade = function(id) {
    if (!confirm('Tem certeza que deseja excluir este projeto?')) return;
    
    this.data.viabilidade = this.data.viabilidade.filter(p => p.id !== id);
    this.saveData(this.data);
    this.notification.show('Projeto excluído!', 'success');
    this.renderViabilidade();
};

// Editar projeto
AppManager.prototype.editViabilidade = function(id) {
    const projeto = this.data.viabilidade.find(p => p.id === id);
    if (projeto) {
        this.showViabilidadeForm(projeto);
    }
};

// Initialize app
// Inicialização global
document.addEventListener('DOMContentLoaded', () => {
    window.app = new AppManager();
});
            <div class="form-row">
